#!/bin/sh
# Args: $1 = previous HEAD, $2 = new HEAD, $3 = checkout flag (1 = branch checkout)
# Regenerate only on branch switches that actually changed project.yml.

[ "$3" = "1" ] || exit 0  # ignore file checkouts (e.g. `git checkout -- file`)

if ! git diff --quiet "$1" "$2" -- project.yml 2>/dev/null; then
  exec "$(dirname "$0")/regenerate-project.sh"
fi
